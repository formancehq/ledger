tag := "antithesis"

build-manifest output *ARGS:
	rm -f -- '{{output}}'
	helm dependency update
	helm dependency build
	helm template . \
	    --values values.yaml \
	    --set run_tag={{tag}} \
	    --include-crds {{ARGS}} > '{{output}}'

push *ARGS:
	#!/usr/bin/env bash

	set -euxo pipefail
	tmpdir=$(mktemp -d)
	trap 'rm -rf $tmpdir' EXIT

	just build-manifest "$tmpdir/resources.yaml" {{ARGS}}

	docker build --platform linux/amd64 -f Dockerfile.config -t $ANTITHESIS_REPOSITORY/antithesis-config-ledger-v3:{{tag}} $tmpdir
	docker push $ANTITHESIS_REPOSITORY/antithesis-config-ledger-v3:{{tag}}

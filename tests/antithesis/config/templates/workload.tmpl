apiVersion: v1
kind: Pod
metadata:
  name: workload
  namespace: formance-systems
  labels:
    app: workload
spec:
  containers:
    - name: workload
      image: us-central1-docker.pkg.dev/molten-verve-216720/formance-repository/workload-ledger-v3:{{ .Values.run_tag }}
      imagePullPolicy: IfNotPresent
      env:
        - name: LEDGER_GRPC_ADDR
          value: "stack0-ledger.stack0.svc.cluster.local:8888"
        - name: EXPECTED_VOTERS
          value: "{{ .Values.replicas }}"
      readinessProbe:
        # grpc:
        #   port: 8888
        #   service: "stack0-ledger.stack0.svc.cluster.local"
        exec:
          command: ["/bin/grpc_health_probe", "-addr=$(LEDGER_GRPC_ADDR)"]
        initialDelaySeconds: 3
        periodSeconds: 3
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: stack-updater
rules:
  - apiGroups: ["formance.com"]
    resources: ["ledgers", "stacks"]
    verbs: ["get", "list", "watch", "update", "patch", "create"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: stack-updater-binding
subjects:
  - kind: ServiceAccount
    name: default
    namespace: formance-systems
roleRef:
  kind: ClusterRole
  name: stack-updater
  apiGroup: rbac.authorization.k8s.io

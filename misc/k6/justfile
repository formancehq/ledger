
# Create k6 archive for a test script
# Usage: just k6-create-archive world_to_bank.js
k6-create-archive SCRIPT:
    #!/usr/bin/env bash
    set -e
    SCRIPT_NAME="{{SCRIPT}}"
    SCRIPT_PATH="./scripts/${SCRIPT_NAME}"
    ARCHIVE_NAME="${SCRIPT_NAME%.js}.tar"
    ARCHIVE_PATH="./archives/${ARCHIVE_NAME}"
    rm -f $ARCHIVE_PATH
    
    # Check if script exists
    if [ ! -f "${SCRIPT_PATH}" ]; then
        echo "Error: Script ${SCRIPT_PATH} not found"
        exit 1
    fi
    
    # Create archives directory if it doesn't exist
    mkdir -p archives
    
    # Generate k6 archive
    echo "Creating k6 archive for ${SCRIPT_NAME}..."
    cd scripts
    k6 archive "${SCRIPT_NAME}" -O "../archives/${ARCHIVE_NAME}"
    cd ..
    
    echo "✓ Archive ${ARCHIVE_NAME} created successfully"

# Install k6 TestRun from Helm chart (creates ConfigMap and TestRun)
# Usage: just k6-run any_unbounded_to_any.js values.yaml
k6-run SCRIPT VALUES_FILE:
    #!/usr/bin/env bash
    set -e
    SCRIPT_NAME="{{SCRIPT}}"
    SCRIPT_BASE="${SCRIPT_NAME%.js}"
    ARCHIVE_NAME="${SCRIPT_BASE}.tar"
    ARCHIVE_PATH="./archives/${ARCHIVE_NAME}"
    RELEASE_NAME="k6-run-${SCRIPT_BASE//_/-}"
    VALUES_FILE="{{VALUES_FILE}}"
    
    # Check if script exists
    if [ ! -f "scripts/${SCRIPT_NAME}" ]; then
        echo "Error: Script scripts/${SCRIPT_NAME} not found"
        exit 1
    fi
    
    # Check if values file exists
    if [ ! -f "${VALUES_FILE}" ]; then
        echo "Error: Values file ${VALUES_FILE} not found"
        exit 1
    fi
    
    # Extract namespace from values file (default to ledger-v3)
    NAMESPACE=$(yq -r '.metadata.namespace // "ledger-v3"' "${VALUES_FILE}")
    
    # Check if archive exists, create it if not
    if [ ! -f "${ARCHIVE_PATH}" ]; then
        echo "Archive ${ARCHIVE_PATH} not found. Creating it..."
        just k6-create-archive {{SCRIPT}}
    fi
    
    # Encode archive to base64
    ARCHIVE_BASE64=$(base64 -i "${ARCHIVE_PATH}" | tr -d '\n')
    
    # Install TestRun from Helm chart (creates ConfigMap and TestRun, optionally Job)
    echo "Installing k6 TestRun for ${SCRIPT_NAME} with values from ${VALUES_FILE}..."
    helm upgrade --install \
        "${RELEASE_NAME}" \
        run-chart \
        --namespace "${NAMESPACE}" \
        --create-namespace \
        --values "${VALUES_FILE}" \
        --set "script=${SCRIPT_BASE}" \
        --set "archiveData=${ARCHIVE_BASE64}"
    
    echo "✓ TestRun installed: ${RELEASE_NAME} in namespace ${NAMESPACE}"

          "editorMode": "code",
          "expr": "deriv(readindex.tx.page_writes_total{service.cluster=~\"$cluster\", service.node_id=~\"$node\"}[$__rate_interval])",
          "legendFormat": "Node {{service.node_id}}",
          "range": true,
          "refId": "A"
        }

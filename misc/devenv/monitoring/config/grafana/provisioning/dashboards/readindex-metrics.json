      "title": "Page Read Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "description": "Rate of bbolt page writes across all write transactions, derived from cumulative `TxStats.PageAlloc / PageSize`.\n\nCorrelates with index builder write activity. A spike usually follows a burst of Raft log entries being indexed. If write rate is consistently high while freelist bytes also grow, the index file may be fragmenting — consider scheduling a compaction.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,

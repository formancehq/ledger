controller-gen := "go run sigs.k8s.io/controller-tools/cmd/controller-gen@latest"

generate:
    {{controller-gen}} object:headerFile="" paths=./api/... \
        crd output:crd:dir=config/crd/bases \
        rbac:roleName=benchmark-operator output:rbac:dir=config/rbac paths=./...
    @just _sync-chart

_sync-chart:
    ./scripts/sync-chart-rbac.sh
    mkdir -p chart/crds
    cp config/crd/bases/*.yaml chart/crds/

build:
    go build -o build/benchmark-operator ./cmd/benchmark-operator

test:
    KUBEBUILDER_ASSETS="$(setup-envtest use -p path)" go test -tags integration ./... -timeout 180s

pre-commit: generate
    go mod tidy
    go build ./...

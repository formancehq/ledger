controller-gen := "go run sigs.k8s.io/controller-tools/cmd/controller-gen@latest"

generate:
    {{controller-gen}} object:headerFile="" paths=./api/... \
        crd output:crd:dir=config/crd/bases \
        rbac:roleName=ledger-operator output:rbac:dir=config/rbac paths=./...
    @just _sync-chart

# Sync generated RBAC rules into the Helm chart ClusterRole template.
# controller-gen produces config/rbac/role.yaml from kubebuilder annotations;
# this script injects those rules into the chart and appends static extras.
_sync-chart:
    ./scripts/sync-chart-rbac.sh
    mkdir -p chart/crds
    cp config/crd/bases/*.yaml chart/crds/

build:
    go build -o build/operator ./cmd/operator

test:
    go test ./...

build-plugin:
    go build -o build/kubectl-ledger ./cmd/kubectl-ledger

install-plugin:
    go build -o $(go env GOPATH)/bin/kubectl-ledger ./cmd/kubectl-ledger

pre-commit: generate
    go mod tidy
    go build ./...
